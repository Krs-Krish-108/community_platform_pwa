# ============================================================
# Verified Community Directory PWA — Backend Environment
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ============================================================

# ── Runtime ──────────────────────────────────────────────────
APP_MODE=development           # development | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
APP_VERSION=1.0.0

# ── Origins ──────────────────────────────────────────────────
# Frontend URL (used for CORS and WebAuthn origin validation)
APP_ORIGIN=http://localhost:5173
# Backend API URL
API_ORIGIN=http://localhost:8000
# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ─────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=community_directory

# ── Session Security ─────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SESSION_SECRET_KEY=CHANGE_ME_generate_a_64_byte_hex_secret
DEVICE_TOKEN_SECRET_KEY=CHANGE_ME_generate_another_64_byte_hex_secret
SESSION_EXPIRE_HOURS=24
DEVICE_COOKIE_EXPIRE_DAYS=90

# ── WebAuthn / Passkeys ───────────────────────────────────────
# Must match the domain your PWA is served from (no port, no https://)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Community Directory
# Comma-separated full origins (with https://)
WEBAUTHN_ORIGINS=http://localhost:5173

# ── OTP Settings ─────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_DAILY_CAP=10

# ── Email / SMTP ─────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=CHANGE_ME_your_smtp_password
OTP_FROM_EMAIL=noreply@yourdomain.com
OTP_FROM_NAME=Community Directory

# ── Object Storage (Cloudflare R2 / S3-compatible) ───────────
OBJECT_STORAGE_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
OBJECT_STORAGE_BUCKET=community-media
OBJECT_STORAGE_ACCESS_KEY=CHANGE_ME
OBJECT_STORAGE_SECRET_KEY=CHANGE_ME
OBJECT_STORAGE_PUBLIC_BASE_URL=

# ── Media Limits ─────────────────────────────────────────────
MEDIA_MAX_IMAGE_MB=5
MEDIA_MAX_VIDEO_MB=20
MEDIA_SIGNED_URL_EXPIRE_SECONDS=3600

# ── Rate Limits ──────────────────────────────────────────────
RATE_LIMIT_IDENTIFY_PER_15MIN=5
RATE_LIMIT_OTP_RESEND_PER_HOUR=5
RATE_LIMIT_POST_PER_HOUR=20

# ── Admin Bootstrap ──────────────────────────────────────────
# Used ONLY on first boot to create the first administrator.
# After bootstrap completes, these have no effect.
# Remove from environment once the first admin account is active.
ADMIN_BOOTSTRAP_EMAIL=admin@yourdomain.com
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_strong_password_min_12_chars

# ── Security Thresholds ───────────────────────────────────────
SECURITY_FLAG_OTP_FAIL_THRESHOLD=10
SECURITY_FLAG_DEVICE_INVALID_THRESHOLD=5
SECURITY_FLAG_IDENTITY_MISMATCH_THRESHOLD=10

# ── Polling Intervals (ms) ───────────────────────────────────
# These are consumed by the frontend; kept here for reference
INBOX_POLL_INTERVAL_MS=45000
EMERGENCY_POLL_INTERVAL_MS=15000
